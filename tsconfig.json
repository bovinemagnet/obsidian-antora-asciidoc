{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "lib": ["DOM", "ES2020"],
    "types": ["node"],
    "outDir": "dist"
  },
  "include": ["main.ts", "src/**/*.ts", "esbuild.config.mjs"]
}

{
  "name": "obsidian-antora-asciidoc",
  "version": "0.2.0",
  "description": "Obsidian plugin for Antora-focused AsciiDoc authoring",
  "main": "main.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs --production",
    "lint": "eslint . --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench --run",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "antora",
    "asciidoc"
  ],
  "author": "bovinemagnet",
  "license": "Apache-2.0",
  "devDependencies": {
    "@codemirror/autocomplete": "6.18.6",
    "@codemirror/language": "6.11.3",
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.38.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.17.57",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.1",
    "obsidian": "^1.8.10",
    "typescript": "5.5.4",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "asciidoctor": "^3.0.4",
    "js-yaml": "^4.1.1"
  }
}
